# VisorUp Agent System — Environment Variables
# Copy this to .env and fill in values

# ── Google OAuth (GA4 + Search Console) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── GA4 ──
GA4_PROPERTY_ID=

# ── Search Console ──
SEARCH_CONSOLE_SITE_URL=https://visorup.com
SITE_URL=https://visorup.com
SITEMAP_URL=https://visorup.com/sitemap.xml

# ── Anthropic (Claude — content generation) ──
ANTHROPIC_API_KEY=

# ── Gemini (Image generation) ──
GEMINI_API_KEY=

# ── GitHub (repo write access for content agents) ──
GITHUB_TOKEN=
GITHUB_REPO=GlobalBookings/visorup

# ── Slack (webhook for reports) ──
SLACK_WEBHOOK_URL=

# ── Server ──
APPROVAL_PORT=3100
LOG_LEVEL=info
